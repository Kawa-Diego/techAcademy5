{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@prisma/client": ["./src/generated/prisma/client"],
      "@ecommerce/shared": ["./src/shared/index.ts"],
      "@ecommerce/shared/*": ["./src/shared/*"]
    }
  },
  "include": ["src/**/*"]
}
