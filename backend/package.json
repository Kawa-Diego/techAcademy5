  "devDependencies": {
    "@prisma/client": "^7.7.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.19.17",
    "@types/pg": "^8.11.11",
    "@types/supertest": "^6.0.2",
    "i": "^0.3.7",
